{
  "name": "ppixiv-kemono",
  "version": "1.9.3",
  "description": "Add kemono.su patreon & fanbox & fantia links into ppixiv",
  "homepage": "https://pixiv.net",
  "module": "esm",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "ENVIRONMENT=development tsdown --config-loader unrun --watch",
    "build": "tsdown --config-loader unrun && cp -f build/index.user.js .",
    "serve": "http-server build -a 127.0.0.1 -d false -i false -c-1 -o index.proxy.user.js",
    "lint:tsc": "eslint src/**/*.ts src/*.ts",
    "lint:eslint": "eslint src/**/*.ts src/*.ts",
    "lint:fix": "eslint --fix src/**/*.ts src/*.ts",
    "lint": "npm run lint:tsc && npm run lint:eslint",
    "release": "npm run build && git add index.user.js && npm version --force -m 'chore(release): %s' --",
    "postversion": "git push & git push --tags"
  },
  "keywords": [],
  "repository": {
    "url": "https://github.com/EnergoStalin/ppixiv-kemono"
  },
  "author": "EnergoStalin",
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/node": "^24.1.0",
    "@types/tampermonkey": "^5.0.5",
    "esbuild-plugin-userscript": "^0.2.6",
    "eslint": "^8.57.1",
    "eslint-kit": "^11.38.0",
    "http-server": "^14.1.1",
    "prettier": "^3.5.0",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "unplugin-plugin-userscript": "^0.3.1",
    "unrun": "^0.3.1"
  },
  "volta": {
    "node": "24.18.0"
  }
}
